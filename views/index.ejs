<!DOCTYPE html>
<html>
  <head>
    <title>Purchase Parking</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container">
      <h1>Purchase Parking</h1>

      <form action="/parking/purchase" method="POST">
        <label for="licensePlate">License Plate (example: ABC123):</label>
        <input type="text" id="licensePlate" name="licensePlate" />

        <label for="duration">Parking Duration (hours):</label>
        <input type="text" id="duration" name="duration" />

        <button type="submit" class="btn">Purchase Parking</button>
      </form>
    </div>
  </body>
</html>
